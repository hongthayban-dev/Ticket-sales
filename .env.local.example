# ===== Google APIs =====
# Service Account JSON (base64 encoded): cat service-account.json | base64
GOOGLE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-service-account-json

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id

# Google Drive (legacy - unused if using Cloudinary)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SLIP_FOLDER_ID=
GOOGLE_DRIVE_BANNER_FOLDER_ID=
GOOGLE_DRIVE_QR_FOLDER_ID=
GOOGLE_DRIVE_EVENT_FOLDER_ID=

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== LINE =====
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_LIFF_ID=your-liff-id
NEXT_PUBLIC_LIFF_ID=your-liff-id

ADMIN_LINE_USER_ID=your-admin-line-user-id

# ===== Email (Gmail) =====
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com

# ===== Auth =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SUPER_ADMIN_TOKEN=your-super-admin-token-change-this

# ===== App =====
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Ticket sales

# ===== PromptPay =====
PROMPTPAY_NUMBER=0812345678
